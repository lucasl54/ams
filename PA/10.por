programa {
  funcao inicio() {
    
    real num1, num2, num3, num1_num2_num3

    escreva("digite o primeiro numero: ")
    leia(num1)
    escreva("digite o segundo numero: ")
    leia(num2)
    escreva("digite o terceiro numero: ")
    leia(num3)

    num1_num2_num3=(num1*num1)+(num2*num2)+(num3*num3)

    escreva("a soma de tres numeros ao quadrado é:",num1_num2_num3)

  }
}
